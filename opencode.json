{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "ask",

      "cargo check": "allow",
      "cargo check *": "allow",
      "cargo build": "allow",
      "cargo build *": "allow",
      "cargo run": "allow",
      "cargo run *": "allow",
      "cargo test": "allow",
      "cargo test *": "allow",
      "cargo clippy": "allow",
      "cargo clippy *": "allow",
      "cargo fmt": "allow",
      "cargo fmt *": "allow",


      ".riprap/managed/skills/rr-plan/rqm.sh": "allow",
      ".riprap/managed/skills/rr-plan/rqm.sh *": "allow"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.claude/.credentials.json": "deny",
      "**/.codex/auth.json": "deny",
      "**/.opencode/data/opencode/auth.json": "deny"
    }
  }
}
