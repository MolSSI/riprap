FROM {{ base_image }}

ENV DEBIAN_FRONTEND=noninteractive

# The image runs as root under a runtime that maps the caller to root and as the
# invoking user under one that does not, so nothing it installs may live under
# /root, which no other user can read or traverse. Every program, toolchain, and
# agent configuration home sits beneath one image-owned home directory instead.
ENV HOME=/opt/riprap/home
ENV PATH="/opt/riprap/home/.local/bin:$PATH"
RUN mkdir -p /opt/riprap/home && chmod 0755 /opt/riprap /opt/riprap/home

# Base tooling. jq is needed for the requirements index script; curl and
# ca-certificates support project tooling and the separate agent image.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        pipx && \
    rm -rf /var/lib/apt/lists/*

# Install Copier as an isolated CLI application for template updates and validation.
RUN pipx install 'copier>=9,<10'

{% if language == "rust" %}
# Install Rust
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential && \
    rm -rf /var/lib/apt/lists/*
ENV RUST_VERSION=1.93.0
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --default-toolchain ${RUST_VERSION}
ENV PATH="/opt/riprap/home/.cargo/bin:${PATH}"
{% endif %}
{% if language == "python" %}
# Install Python tooling
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip python3-venv && \
    pip3 install --break-system-packages bandit pylint && \
    rm -rf /var/lib/apt/lists/*
{% endif %}

# Installers create their files for the building user alone. Grant read and, for
# directories and executables, traverse and execute to everyone, so an arbitrary
# unprivileged user reaches the same toolchain the building user installed.
RUN chmod -R a+rX /opt/riprap
