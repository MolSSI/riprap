#!/bin/sh
# Riprap keeps OpenCode's durable XDG data, state, and user configuration in one
# project-scoped credential mount without redirecting other programs' XDG state.
# The cache holds only re-derivable downloads, so it stays in the disposable
# container. The paths sit under the image-owned home directory, which every
# supported runtime presents at the same location whatever user it runs as.
export XDG_DATA_HOME=/opt/riprap/home/.opencode/data
export XDG_STATE_HOME=/opt/riprap/home/.opencode/state
export OPENCODE_CONFIG_DIR=/opt/riprap/home/.opencode/config
# OpenCode derives and creates the XDG directories itself, but it writes into
# OPENCODE_CONFIG_DIR without creating it and fails on a directory that is absent.
# The credential mount covers /opt/riprap/home/.opencode at run time, so the agent
# image cannot prepare these paths; a launch into fresh storage has to create them.
mkdir -p /opt/riprap/home/.opencode/data /opt/riprap/home/.opencode/state /opt/riprap/home/.opencode/config
exec /opt/opencode/bin/opencode "$@"
