name: CI

permissions:
  contents: read

on:
  push:
    branches:
      - "main"
  pull_request:
    branches:
      - "main"
  schedule:
    # Weekly tests run on main by default:
    #   Scheduled workflows run on the latest commit on the default or base branch.
    #   (from https://help.github.com/en/actions/reference/events-that-trigger-workflows#scheduled-events-schedule)
    - cron: "0 0 * * 0"

jobs:
  test:
    name: Test on {{ '${{ matrix.os }}' }}, Python {{ '${{ matrix.python-version }}' }}
    runs-on: {{ '${{ matrix.os }}' }}
    strategy:
      matrix:
        os: [macOS-latest, ubuntu-latest, windows-latest]
        python-version: ["3.11", "3.12", "3.13"]

    steps:
      - uses: actions/checkout@v4

      - name: Reject committed credentials
        if: runner.os == 'Linux'
        run: .riprap/managed/hooks/check-secrets.sh --repository

      - name: Additional info about the build
        shell: bash
        run: |
          uname -a
          df -h
          ulimit -a
{% if dependency_source == "Dependencies from pip only (no conda)" %}
      - name: Set up Python {{ '${{ matrix.python-version }}' }}
        uses: actions/setup-python@v5
        with:
          python-version: {{ '${{ matrix.python-version }}' }}

      - name: Install package
        shell: bash
        run: |
          python -m pip install -e ".[test]" pytest-cov

      - name: Run tests
        shell: bash
        run: |
          pytest -v --cov={{ package_name }} --cov-report=xml --color=yes tests/
{% else %}
      # More info on options: https://github.com/marketplace/actions/setup-micromamba
      - uses: mamba-org/setup-micromamba@v2
        with:
          environment-file: devtools/conda-envs/test_env.yaml
          environment-name: test
{% if dependency_source == "Prefer conda-forge with pip fallback" %}
          condarc: |
            channels:
              - conda-forge
{% else %}
          condarc: |
            channels:
              - defaults
{% endif %}
          create-args: >-
            python={{ '${{ matrix.python-version }}' }}

      - name: Install package
        # conda setup requires this special shell
        shell: bash -l {0}
        run: |
          python -m pip install . --no-deps
          micromamba list

      - name: Run tests
        # conda setup requires this special shell
        shell: bash -l {0}
        run: |
          pytest -v --cov={{ package_name }} --cov-report=xml --color=yes tests/
{% endif %}
      - name: CodeCov
        uses: codecov/codecov-action@v5
        with:
          files: ./coverage.xml
          flags: unittests
          name: codecov-{{ '${{ matrix.os }}' }}-py{{ '${{ matrix.python-version }}' }}
