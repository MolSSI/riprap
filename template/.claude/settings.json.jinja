{
  "permissions": {
    "allow": [
{% if language == "rust" %}
      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(cargo test:*)",
{% endif %}
{% if language == "python" %}
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(pytest:*)",
      "Bash(pip install:*)",
      "Bash(pylint:*)",
      "Bash(bandit:*)",
{% if use_conda %}
      "Bash(conda:*)",
{% endif %}
{% endif %}
      "Skill(gr-architecture)",
      "Skill(gr-plan)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".guardrails/hooks/check-container.sh"
          }
        ]
      }
    ]
  }
}
