{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "permission": {
    "bash": {
      "*": "ask",
{% if language == "rust" %}
      "cargo check": "allow",
      "cargo check *": "allow",
      "cargo build": "allow",
      "cargo build *": "allow",
      "cargo run": "allow",
      "cargo run *": "allow",
      "cargo test": "allow",
      "cargo test *": "allow",
      "cargo clippy": "allow",
      "cargo clippy *": "allow",
      "cargo fmt": "allow",
      "cargo fmt *": "allow",
{% endif %}
{% if language == "python" %}
      "pytest": "allow",
      "pytest *": "allow",
      "pylint": "allow",
      "pylint *": "allow",
      "bandit": "allow",
      "bandit *": "allow",
{% endif %}
      ".riprap/managed/skills/rr-plan/rqm.sh": "allow",
      ".riprap/managed/skills/rr-plan/rqm.sh *": "allow"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/.claude/.credentials.json": "deny",
      "**/.codex/auth.json": "deny",
      "**/.opencode/data/opencode/auth.json": "deny"
    }
  }
}
