name: docs_{{ project_slug }}
channels:
{% if dependency_source == "Prefer conda-forge with pip fallback" %}
  - conda-forge
{% endif %}
  - defaults
dependencies:
    # Base depends
  - python
  - pip
{% if dependency_source == "Prefer conda-forge with pip fallback" %}
  - sphinx
  - pydata-sphinx-theme
  - sphinx-design
  - sphinx-copybutton

    # Pip-only installs
{% if create_python_skeleton %}
  - pip:
    - -e ../
{% endif %}
{% else %}

  # Pip-only installs
  - pip:
{% if create_python_skeleton %}
    - -e ../
{% endif %}
    - sphinx
    - pydata-sphinx-theme
    - sphinx-design
    - sphinx-copybutton
{% endif %}
