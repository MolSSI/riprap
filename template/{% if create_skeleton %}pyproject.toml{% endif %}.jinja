[build-system]
requires = ["setuptools>=77.0", "versioningit~=3.1"]
build-backend = "setuptools.build_meta"

# Self-descriptive entries which should always be present
# https://packaging.python.org/en/latest/specifications/declaring-project-metadata/
[project]
name = "{{ project_slug }}"
description = "{{ project_description }}"
dynamic = ["version"]
readme = "README.md"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" }
]
# Uncomment once a LICENSE file exists, using the appropriate SPDX identifier:
#license = "MIT"
#license-files = ["LICENSE"]
# See https://pypi.org/classifiers/
classifiers = [
    "Programming Language :: Python :: 3",
]
requires-python = ">=3.10"
# Declare any run-time dependencies that should be installed with the package.
#dependencies = [
#    "importlib-resources;python_version<'3.10'",
#]

# Update the urls once the hosting is set up.
#[project.urls]
#"Source" = "https://github.com/<username>/{{ project_slug }}/"
#"Documentation" = "https://{{ project_slug }}.readthedocs.io/"

[project.optional-dependencies]
test = [
    "pytest>=6.1.2",
]

[tool.setuptools.packages.find]
where = ["src"]
namespaces = false

# Ref https://setuptools.pypa.io/en/latest/userguide/datafiles.html#package-data
[tool.setuptools.package-data]
{{ package_name }} = [
    "py.typed",
]

[tool.versioningit]
default-version = "1+unknown"

[tool.versioningit.format]
distance = "{base_version}+{distance}.{vcs}{rev}"
dirty = "{base_version}+{distance}.{vcs}{rev}.dirty"
distance-dirty = "{base_version}+{distance}.{vcs}{rev}.dirty"

[tool.versioningit.vcs]
method = "git"
match = ["*"]
default-tag = "1.0.0"

[tool.versioningit.write]
file = "src/{{ package_name }}/_version.py"

[tool.coverage.run]
omit = [
    # Omit the tests
    "tests/*",
    # Omit the generated version file
    "src/{{ package_name }}/_version.py",
]
