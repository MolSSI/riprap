FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PATH="$PATH:/root/.local/bin"

# Base tooling. jq is needed for the requirements index script;
# curl + ca-certificates are needed for the agent installers below.
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        curl \
        git \
        jq \
        pipx && \
    rm -rf /var/lib/apt/lists/*

# rq-7983cd9c
# Install Copier as an isolated CLI application for template updates and validation.
RUN pipx install 'copier>=9,<10'

# Install Claude
RUN curl -fsSL https://claude.ai/install.sh | bash

# Install Codex
RUN curl -fsSL https://chatgpt.com/codex/install.sh | sh

{% if language == "rust" %}
# Install Rust
RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential && \
    rm -rf /var/lib/apt/lists/*
ENV RUST_VERSION=1.93.0
RUN curl https://sh.rustup.rs -sSf | sh -s -- -y --default-toolchain ${RUST_VERSION}
ENV PATH="/root/.cargo/bin:${PATH}"
{% endif %}
{% if language == "python" %}
# Install Python tooling
RUN apt-get update && \
    apt-get install -y --no-install-recommends python3 python3-pip python3-venv && \
    pip3 install --break-system-packages bandit pylint && \
    rm -rf /var/lib/apt/lists/*
{% endif %}
