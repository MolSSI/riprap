{
  "permissions": {
    "allow": [

      "Bash(cargo check:*)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(cargo test:*)",
      "Bash(cargo clippy:*)",
      "Bash(cargo fmt:*)",


      "Bash(.riprap/managed/skills/rr-plan/rqm.sh:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./.claude/.credentials.json)",
      "Read(./.codex/auth.json)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".riprap/managed/hooks/check-container.sh"
          }
        ]
      }
    ]
  }
}
